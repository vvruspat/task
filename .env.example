# Complete environment variable reference for the local stack.
# Export the values needed by the services you run, or use an app-specific template.

# -----------------------------------------------------------------------------
# API — apps/api
# -----------------------------------------------------------------------------
PORT=3000
DATABASE_URL=postgresql://task_user:task_password@localhost:5433/task_db

# OpenRouter agent (optional). Set API key and model together to enable the agent.
# OPENROUTER_API_KEY=sk-or-v1-replace-me
# OPENROUTER_MODEL=openai/gpt-4.1-mini
# OPENROUTER_FALLBACK_MODEL=anthropic/claude-sonnet-4
# OPENROUTER_SITE_URL=https://task.example.com
# OPENROUTER_APP_TITLE=tAsk

# Telegram Mini App verification in the API (optional).
# The same token is used by apps/tg-bot below.
# TELEGRAM_BOT_TOKEN=123456789:replace-me
# Internal authorization for requests from apps/tg-bot.
# Must equal TASK_API_BOT_SHARED_SECRET in the Telegram bot block.
# TELEGRAM_BOT_SHARED_SECRET=replace-with-a-long-random-value

# -----------------------------------------------------------------------------
# Web — apps/web
# -----------------------------------------------------------------------------
# Backend API URL used by the web app.
TASK_API_BASE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Telegram bot — apps/tg-bot
# -----------------------------------------------------------------------------
# TELEGRAM_BOT_TOKEN is shared with apps/api and is declared in the API block.
# TASK_API_BASE_URL is shared with apps/web and is declared in the Web block.
# Must equal TELEGRAM_BOT_SHARED_SECRET in the API block.
# TASK_API_BOT_SHARED_SECRET=replace-with-the-same-value-as-telegram-bot-shared-secret
# TELEGRAM_WEBHOOK_SECRET=replace-with-a-random-webhook-secret
# TELEGRAM_BOT_PORT=3001

# -----------------------------------------------------------------------------
# MCP server — apps/mcp-server
# -----------------------------------------------------------------------------
# TASK_API_BASE_URL is shared with apps/web and is declared in the Web block.
# TASK_MCP_SERVER_NAME=task-mcp-server
# TASK_MCP_SERVER_VERSION=0.0.0

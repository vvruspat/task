# Required Telegram bot token from BotFather.
TELEGRAM_BOT_TOKEN=123456789:replace-me
# BotFather username without @; enables exact mention matching in group chats.
TELEGRAM_BOT_USERNAME=task_agent_bot

# Required API connection settings.
TASK_API_BASE_URL=http://localhost:3000
# Must equal TELEGRAM_BOT_SHARED_SECRET in apps/api/.env.
TASK_API_BOT_SHARED_SECRET=replace-with-a-long-random-value

# Optional webhook verification secret.
# TELEGRAM_WEBHOOK_SECRET=replace-with-a-random-webhook-secret

# HTTP port. Defaults to 3001.
TELEGRAM_BOT_PORT=3001

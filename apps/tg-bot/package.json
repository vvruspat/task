{
  "name": "@task/tg-bot",
  "version": "0.0.0",
  "private": true,
  "description": "Telegram bot application for tAsk.",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test \"dist/**/*.test.js\""
  }
}

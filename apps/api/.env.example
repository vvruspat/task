# HTTP port. Defaults to 3000.
PORT=3000

# PostgreSQL connection used by the API and database migrations.
DATABASE_URL=postgresql://task_user:task_password@localhost:5433/task_db

# OpenRouter is optional. Set API key and model together to enable the agent.
# OPENROUTER_API_KEY=sk-or-v1-replace-me
# OPENROUTER_MODEL=openai/gpt-4.1-mini
# OPENROUTER_FALLBACK_MODEL=anthropic/claude-sonnet-4
# OPENROUTER_SITE_URL=https://task.example.com
# OPENROUTER_APP_TITLE=tAsk

# Telegram integration is optional.
# This token is also used by apps/tg-bot as TELEGRAM_BOT_TOKEN.
# TELEGRAM_BOT_TOKEN=123456789:replace-me
# Must equal TASK_API_BOT_SHARED_SECRET in apps/tg-bot/.env.
# TELEGRAM_BOT_SHARED_SECRET=replace-with-a-long-random-value

# Brevo transactional email is optional. The template must define its sender and subject and use
# the username, workspace_name, and link parameters.
# BREVO_API_KEY=xkeysib-replace-me
# BREVO_TEMPLATE_ID=6
# WEB_APP_URL=https://task.example.com

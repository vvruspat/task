# HTTP port. Defaults to 3000.
PORT=3000

# PostgreSQL connection used by the API and database migrations.
DATABASE_URL=postgresql://task_user:task_password@localhost:5433/task_db

# OpenRouter is optional. Set API key and model together to enable the agent.
# OPENROUTER_API_KEY=sk-or-v1-replace-me
# OPENROUTER_MODEL=openai/gpt-4.1-mini
# OPENROUTER_FALLBACK_MODEL=anthropic/claude-sonnet-4
# OPENROUTER_SITE_URL=https://task.example.com
# OPENROUTER_APP_TITLE=tAsk

# Telegram integration is optional.
# This token is also used by apps/tg-bot as TELEGRAM_BOT_TOKEN.
# TELEGRAM_BOT_TOKEN=123456789:replace-me
# Must equal TASK_API_BOT_SHARED_SECRET in apps/tg-bot/.env.
# TELEGRAM_BOT_SHARED_SECRET=replace-with-a-long-random-value

# Brevo transactional email is optional. The template must define its sender and subject and use
# the username, workspace_name, and link parameters.
# BREVO_API_KEY=xkeysib-replace-me
# BREVO_TEMPLATE_ID=6
# WEB_APP_URL=https://task.example.com

# Workspace integrations (required before an integration can store OAuth credentials).
# Generate a unique key per environment with: openssl rand -base64 32
# INTEGRATION_SECRET_ENCRYPTION_KEY=replace-with-a-base64-encoded-32-byte-key
# Absolute local root used to resolve file attachment storage keys for integration exports.
# ATTACHMENT_STORAGE_ROOT=/var/lib/task/attachments

# Google Drive OAuth (optional). Register the redirect URI in Google Cloud exactly as configured.
# GOOGLE_DRIVE_CLIENT_ID=replace-me.apps.googleusercontent.com
# GOOGLE_DRIVE_CLIENT_SECRET=replace-me
# GOOGLE_DRIVE_REDIRECT_URI=https://task.example.com/api/integrations/google-drive/callback
# Google Picker API credentials used to select the workspace root folder.
# Restrict the developer key to the web app origins and Google Picker API.
# GOOGLE_DRIVE_PICKER_API_KEY=replace-me
# GOOGLE_DRIVE_PICKER_APP_ID=123456789012
# Public HTTPS endpoint registered for Google Drive change notifications.
# GOOGLE_DRIVE_WEBHOOK_URL=https://task.example.com/api/integrations/webhooks/google-drive

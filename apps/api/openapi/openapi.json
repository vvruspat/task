{
  "openapi": "3.0.0",
  "paths": {
    "/": {
      "get": {
        "operationId": "AppController_getRoot",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponseDto"
                }
              }
            }
          }
        },
        "summary": "Get API health",
        "tags": ["health"]
      }
    },
    "/health": {
      "get": {
        "operationId": "AppController_getHealth",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponseDto"
                }
              }
            }
          }
        },
        "summary": "Get API health",
        "tags": ["health"]
      }
    },
    "/workspaces": {
      "get": {
        "operationId": "WorkspacesController_listWorkspaces",
        "parameters": [
          {
            "name": "x-task-user-id",
            "in": "header",
            "description": "Temporary trusted user context header until AuthModule owns request identity. Not an authentication mechanism.",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/WorkspaceSummaryDto"
                  }
                }
              }
            }
          }
        },
        "summary": "List workspaces visible to the current user",
        "tags": ["workspaces"]
      }
    },
    "/workspaces/{workspaceId}": {
      "get": {
        "operationId": "WorkspacesController_getWorkspace",
        "parameters": [
          {
            "name": "x-task-user-id",
            "in": "header",
            "description": "Temporary trusted user context header until AuthModule owns request identity. Not an authentication mechanism.",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "workspaceId",
            "required": true,
            "in": "path",
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WorkspaceDetailDto"
                }
              }
            }
          },
          "404": {
            "description": "Workspace is missing or not visible to the current user."
          }
        },
        "summary": "Get one workspace with members",
        "tags": ["workspaces"]
      }
    },
    "/workspaces/{workspaceId}/members": {
      "get": {
        "operationId": "WorkspacesController_listMembers",
        "parameters": [
          {
            "name": "x-task-user-id",
            "in": "header",
            "description": "Temporary trusted user context header until AuthModule owns request identity. Not an authentication mechanism.",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "workspaceId",
            "required": true,
            "in": "path",
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/WorkspaceMemberDto"
                  }
                }
              }
            }
          },
          "404": {
            "description": "Workspace is missing or not visible to the current user."
          }
        },
        "summary": "List members for one visible workspace",
        "tags": ["workspaces"]
      }
    },
    "/workspaces/{workspaceId}/projects": {
      "get": {
        "operationId": "ProjectsController_listActiveProjects",
        "parameters": [
          {
            "name": "x-task-user-id",
            "in": "header",
            "description": "Temporary trusted user context header until AuthModule owns request identity. Not an authentication mechanism.",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "workspaceId",
            "required": true,
            "in": "path",
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ProjectSummaryDto"
                  }
                }
              }
            }
          },
          "404": {
            "description": "Workspace is missing or not visible to the current user."
          }
        },
        "summary": "List active projects in a visible workspace",
        "tags": ["projects"]
      }
    },
    "/workspaces/{workspaceId}/projects/{projectId}": {
      "get": {
        "operationId": "ProjectsController_getProject",
        "parameters": [
          {
            "name": "x-task-user-id",
            "in": "header",
            "description": "Temporary trusted user context header until AuthModule owns request identity. Not an authentication mechanism.",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "workspaceId",
            "required": true,
            "in": "path",
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          },
          {
            "name": "projectId",
            "required": true,
            "in": "path",
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectDetailDto"
                }
              }
            }
          },
          "404": {
            "description": "Workspace or project is missing or not visible to the current user."
          }
        },
        "summary": "Get one project in a visible workspace",
        "tags": ["projects"]
      }
    }
  },
  "info": {
    "title": "tAsk API",
    "description": "Backend API contract for tAsk.",
    "version": "0.0.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "schemas": {
      "HealthResponseDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Current API health status.",
            "enum": ["ok"],
            "example": "ok"
          },
          "service": {
            "type": "string",
            "description": "Service identifier.",
            "example": "api"
          },
          "version": {
            "type": "string",
            "description": "API package version.",
            "example": "0.0.0"
          }
        },
        "required": ["status", "service", "version"]
      },
      "WorkspaceSummaryDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string",
            "example": "Studio"
          },
          "slug": {
            "type": "string",
            "example": "studio"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": ["id", "name", "slug", "createdAt", "updatedAt"]
      },
      "WorkspaceMemberDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "workspaceId": {
            "type": "string",
            "format": "uuid"
          },
          "userId": {
            "type": "string",
            "format": "uuid"
          },
          "role": {
            "type": "string",
            "enum": ["owner", "admin", "member", "guest"]
          },
          "displayName": {
            "type": "string",
            "example": "Alex"
          },
          "email": {
            "type": "string",
            "nullable": true,
            "example": "alex@example.com"
          },
          "avatarUrl": {
            "type": "string",
            "nullable": true,
            "example": "https://example.com/avatar.png"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": ["id", "workspaceId", "userId", "role", "displayName", "createdAt", "updatedAt"]
      },
      "WorkspaceDetailDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string",
            "example": "Studio"
          },
          "slug": {
            "type": "string",
            "example": "studio"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          },
          "members": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/WorkspaceMemberDto"
            }
          }
        },
        "required": ["id", "name", "slug", "createdAt", "updatedAt", "members"]
      },
      "ProjectSummaryDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "workspaceId": {
            "type": "string",
            "format": "uuid"
          },
          "title": {
            "type": "string",
            "example": "Album release"
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "status": {
            "type": "string",
            "nullable": true,
            "example": "active"
          },
          "position": {
            "type": "string",
            "nullable": true,
            "example": "1000"
          },
          "createdByUserId": {
            "type": "string",
            "format": "uuid"
          },
          "archivedAt": {
            "format": "date-time",
            "type": "string",
            "nullable": true
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": ["id", "workspaceId", "title", "createdByUserId", "createdAt", "updatedAt"]
      },
      "ProjectDetailDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "workspaceId": {
            "type": "string",
            "format": "uuid"
          },
          "title": {
            "type": "string",
            "example": "Album release"
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "status": {
            "type": "string",
            "nullable": true,
            "example": "active"
          },
          "position": {
            "type": "string",
            "nullable": true,
            "example": "1000"
          },
          "createdByUserId": {
            "type": "string",
            "format": "uuid"
          },
          "archivedAt": {
            "format": "date-time",
            "type": "string",
            "nullable": true
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": ["id", "workspaceId", "title", "createdByUserId", "createdAt", "updatedAt"]
      }
    }
  }
}

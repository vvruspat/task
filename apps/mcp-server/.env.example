# Required backend API URL.
TASK_API_BASE_URL=http://localhost:3000

# Optional MCP server metadata.
TASK_MCP_SERVER_NAME=task-mcp-server
TASK_MCP_SERVER_VERSION=0.0.0

# Optional controlled integration-tool scope. Configure both values or neither.
# The MCP process discovers connected read-only tools for this user and workspace at startup.
TASK_MCP_USER_ID=
TASK_MCP_WORKSPACE_ID=

{
  "name": "@task/web",
  "version": "0.0.0",
  "private": true,
  "description": "React web application for tAsk.",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json && vite build",
    "dev": "vite --host 0.0.0.0",

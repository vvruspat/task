{
  "name": "@task/api-client",
  "version": "0.0.0",
  "private": true,
  "description": "Generated API client and types for tAsk.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node -e \"console.log('No tests yet for @task/api-client')\"",
    "generate:api-client": "openapi-typescript ../../apps/api/openapi/openapi.json -o src/generated/openapi.ts && biome format --write src/generated/openapi.ts"
  },
  "devDependencies": {
    "openapi-typescript": "^7.13.0"
  }
}

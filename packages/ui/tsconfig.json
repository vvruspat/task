{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.package.json",
  "compilerOptions": {
    "declarationMap": false,
    "emitDeclarationOnly": false,
    "jsx": "react-jsx",
    "outDir": "dist",
    "rootDir": "src",
    "tsBuildInfoFile": "dist/tsconfig.tsbuildinfo"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}

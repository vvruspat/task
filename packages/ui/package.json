{
  "name": "@task/ui",
  "version": "0.0.0",
  "private": true,
  "description": "Shared UI package for tAsk.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles/index.css",
    "./styles/index.css": "./dist/styles/index.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && find src -type f \\( -name '*.css' -o -name '*.woff2' \\) -exec sh -c 'mkdir -p \"dist/$(dirname \"${1#src/}\")\" && cp \"$1\" \"dist/${1#src/}\"' sh {} \\;",
    "lint": "biome check package.json tsconfig.json",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc -p tsconfig.json --noEmit --tsBuildInfoFile dist/tsconfig.typecheck.tsbuildinfo",
    "test": "node -e \"console.log('No tests yet for @task/ui')\""
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@internationalized/date": "^3.12.1",
    "clsx": "^2.1.1",
    "js-convert-case": "^4.2.0",
    "mime-types": "^3.0.2",
    "react-aria-components": "^1.17.0",
    "react-virtuoso": "^4.18.3",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@types/mime-types": "^3.0.1",
    "@types/react": "^19.2.17"
  }
}

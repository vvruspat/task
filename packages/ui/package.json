{
  "name": "@task/ui",
  "version": "0.0.0",
  "private": true,
  "description": "Shared UI package for tAsk.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./app": {
      "types": "./dist/app.d.ts",
      "import": "./dist/app.js"
    },
    "./styles.css": "./dist/styles/radix.css",
    "./styles/index.css": "./dist/styles/radix.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && find src -type f \\( -name '*.css' -o -name '*.woff2' \\) -exec sh -c 'mkdir -p \"dist/$(dirname \"${1#src/}\")\" && cp \"$1\" \"dist/${1#src/}\"' sh {} \\;",
    "lint": "biome check package.json tsconfig.json",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc -p tsconfig.json --noEmit --tsBuildInfoFile dist/tsconfig.typecheck.tsbuildinfo",
    "test": "node -e \"console.log('No tests yet for @task/ui')\""
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.7",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-tooltip": "^1.2.12",
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.17"
  }
}
